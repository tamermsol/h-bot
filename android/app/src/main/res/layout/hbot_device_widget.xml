<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <!-- Header row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/widget_logo"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:contentDescription="H-Bot" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/widget_logo"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:text="H-Bot"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:textSize="12sp"
            android:textColor="#99FFFFFF"
            android:text="" />
    </RelativeLayout>

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="#22FFFFFF" />

    <!-- Device 0 -->
    <RelativeLayout
        android:id="@+id/device_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/device_0_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/device_icon_switch"
            android:contentDescription="device" />

        <TextView
            android:id="@+id/device_0_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/device_0_icon"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_toStartOf="@id/device_0_toggle"
            android:textSize="14sp"
            android:textColor="#E0FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- ON/OFF toggle (for switches/lights) -->
        <TextView
            android:id="@+id/device_0_toggle"
            android:layout_width="52dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="OFF" />

        <!-- Shutter UP arrow -->
        <TextView
            android:id="@+id/device_0_shutter_up"
            android:layout_width="36dp"
            android:layout_height="30dp"
            android:layout_toStartOf="@id/device_0_shutter_down"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="▲"
            android:visibility="gone" />

        <!-- Shutter DOWN arrow -->
        <TextView
            android:id="@+id/device_0_shutter_down"
            android:layout_width="36dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="▼"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Device 1 -->
    <RelativeLayout
        android:id="@+id/device_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/device_1_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/device_icon_switch"
            android:contentDescription="device" />

        <TextView
            android:id="@+id/device_1_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/device_1_icon"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_toStartOf="@id/device_1_toggle"
            android:textSize="14sp"
            android:textColor="#E0FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/device_1_toggle"
            android:layout_width="52dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="OFF" />

        <TextView
            android:id="@+id/device_1_shutter_up"
            android:layout_width="36dp"
            android:layout_height="30dp"
            android:layout_toStartOf="@id/device_1_shutter_down"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="▲"
            android:visibility="gone" />

        <TextView
            android:id="@+id/device_1_shutter_down"
            android:layout_width="36dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="▼"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Device 2 -->
    <RelativeLayout
        android:id="@+id/device_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/device_2_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/device_icon_switch"
            android:contentDescription="device" />

        <TextView
            android:id="@+id/device_2_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/device_2_icon"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_toStartOf="@id/device_2_toggle"
            android:textSize="14sp"
            android:textColor="#E0FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/device_2_toggle"
            android:layout_width="52dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="OFF" />

        <TextView
            android:id="@+id/device_2_shutter_up"
            android:layout_width="36dp"
            android:layout_height="30dp"
            android:layout_toStartOf="@id/device_2_shutter_down"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="▲"
            android:visibility="gone" />

        <TextView
            android:id="@+id/device_2_shutter_down"
            android:layout_width="36dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="▼"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Device 3 -->
    <RelativeLayout
        android:id="@+id/device_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/device_3_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/device_icon_switch"
            android:contentDescription="device" />

        <TextView
            android:id="@+id/device_3_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/device_3_icon"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_toStartOf="@id/device_3_toggle"
            android:textSize="14sp"
            android:textColor="#E0FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/device_3_toggle"
            android:layout_width="52dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="OFF" />

        <TextView
            android:id="@+id/device_3_shutter_up"
            android:layout_width="36dp"
            android:layout_height="30dp"
            android:layout_toStartOf="@id/device_3_shutter_down"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="▲"
            android:visibility="gone" />

        <TextView
            android:id="@+id/device_3_shutter_down"
            android:layout_width="36dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/toggle_off_bg"
            android:text="▼"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Open H-Bot to load devices"
        android:textSize="12sp"
        android:textColor="#66FFFFFF"
        android:visibility="gone" />

</LinearLayout>
