<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>H-Bot uses your location to read your Wi-Fi network name during device setup.</string>
	<key>NSLocationTemporaryUsageDescriptionDictionary</key>
	<dict>
		<key>WifiSSIDRead</key>
		<string>H-Bot needs precise location to read your current Wi-Fi network name for device setup.</string>
	</dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.msol.hbot.background.processing</string>
		<string>com.msol.hbot.background.refresh</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>HBot</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Hbot</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	
	<!-- ========== LOCAL NETWORK PERMISSIONS ========== -->
	<!-- Required for device discovery and provisioning on local network -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>HBot needs access to your local network to discover, configure, and control your smart home devices.</string>
	
	<!-- ========== BONJOUR SERVICES ========== -->
	<!-- Required for mDNS device discovery and to trigger local network permission -->
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
		<string>_http._tcp.</string>
		<string>_tasmota._tcp</string>
		<string>_tasmota._tcp.</string>
		<string>_hbot._tcp</string>
		<string>_hbot._tcp.</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>H-Bot needs camera access to scan QR codes for device setup and sharing.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>H-Bot needs photo library access to set custom background images.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>H-Bot needs microphone access for device communication.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>H-Bot needs local network access to discover and communicate with smart home devices.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>alexa</string>
		<string>amzn</string>
	</array>
</dict>
</plist>